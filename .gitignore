# ===== Secrets — NEVER commit these =====
# Your real Sarvam API key lives in .env. This line keeps it off git forever.
.env

# ===== Python junk =====
__pycache__/
*.pyc
.venv/
venv/
env/

# ===== Tool / editor settings =====
.claude/

# ===== Windows / OS files =====
Thumbs.db
desktop.ini
.DS_Store
~$*

# ===== Audio test scratch files (we'll regenerate these anytime) =====
*.wav.tmp
data/hello_sarvam.wav

# ===== Real PNB documents (copyrighted — keep LOCAL, never commit) =====
# Both the original PDFs and the extracted .txt hold PNB's copyrighted content.
# The repo stays reproducible via src/ingest/ + data/policies/source_manifest.json.
data/policies/source_pdfs/
data/policies/*.txt
data/policies/_ocr_work/

# ===== User's synthetic sample pack — kept locally, NOT used (we use real docs) =====
pnb-knowledge-base.md

# ===== Runtime logs (regenerated as the app is used) =====
logs/

# ===== Local-only helper: a browser page to view the diagram PNGs offline =====
view-diagrams.html
