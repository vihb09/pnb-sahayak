# ----------------------------------------------------------------------
# TEMPLATE FILE — safe to commit. Contains NO real secrets.
#
# How this works:
#   1. Make a copy of this file and name the copy ".env" (no .example).
#   2. In the .env copy, replace the placeholder below with your real key.
#   3. The .env file is ignored by git, so your real key is never uploaded.
# ----------------------------------------------------------------------

# Your Sarvam API key (get it from the Sarvam dashboard).
SARVAM_API_KEY=your_sarvam_api_key_here

# (Phase 4, optional) n8n webhook URL for escalations. Leave blank until you create
# the n8n workflow — the assistant logs tickets locally either way.
N8N_WEBHOOK_URL=
